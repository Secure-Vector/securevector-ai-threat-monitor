{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "SecureVector AI Threat Monitor — OCSF 1.3.0 events via Loki. Data flow: SIEM Forwarder writes NDJSON → Promtail/Alloy ships to Loki → this dashboard. Adjust $job / $datasource variables to match your setup.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Total SecureVector events in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"$job\"} | json | class_uid != \"\" [$__range]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Total events",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Events with severity=BLOCK — prompts the scanner actively stopped.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "red"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"$job\"} | json | severity = \"BLOCK\" [$__range]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "BLOCK",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Events with severity=DETECTED — scanner flagged but did not block.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "orange"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "orange", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"$job\"} | json | severity = \"DETECTED\" [$__range]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "DETECTED",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Tool-call audit events (class_uid=1007) where action=block.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "purple"},
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "purple", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["sum"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum(count_over_time({job=\"$job\"} | json | class_uid = \"1007\" | unmapped_action = \"block\" [$__range]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Tool-call blocks",
      "type": "stat"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Event volume over time, grouped by severity. Peaks = incidents or misbehaving agents.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "bars",
            "fillOpacity": 70,
            "gradientMode": "none",
            "lineInterpolation": "linear",
            "lineWidth": 1,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "auto",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "normal"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 4},
      "id": 5,
      "options": {
        "legend": {"calcs": [], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "sum by (severity) (count_over_time({job=\"$job\"} | json [$__interval]))",
          "legendFormat": "{{severity}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Events over time by severity",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Top scan-finding categories (OCSF detected_types). Loki's JSON parser flattens arrays to indexed keys; this panel counts by the first detected_type which is the scanner's primary classification. For true MITRE ATT&CK breakdown across all matched rules, use the Splunk XML or Sentinel workbook — their parsers handle OCSF technique arrays natively.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 12},
      "id": 6,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Count"}]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "topk(10, sum by (finding_title) (count_over_time({job=\"$job\"} | json | class_uid = \"2001\" [$__range])))",
          "format": "table",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Top finding titles",
      "type": "table"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Top actor.user.name across scans — who (OS login) triggered the most findings?",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "auto",
            "cellOptions": {"type": "auto"},
            "inspect": false
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 12},
      "id": 7,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Count"}]
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "topk(10, sum by (actor_user_name) (count_over_time({job=\"$job\"} | json [$__range])))",
          "format": "table",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Top actors",
      "type": "table"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource}"},
      "description": "Recent high-severity events (BLOCK or DETECTED). Click a line to expand the full OCSF payload.",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 22},
      "id": 8,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${datasource}"},
          "editorMode": "code",
          "expr": "{job=\"$job\"} | json | severity =~ \"BLOCK|DETECTED\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Recent high-severity events",
      "type": "logs"
    }
  ],
