{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "node \"${COPILOT_PLUGIN_ROOT}\"/hooks/session-start.js",
        "timeoutSec": 10
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "node \"${COPILOT_PLUGIN_ROOT}\"/hooks/pre-tool-use.js",
        "matcher": ".*",
        "timeoutSec": 10
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "command": "node \"${COPILOT_PLUGIN_ROOT}\"/hooks/post-tool-use.js",
        "matcher": ".*",
        "timeoutSec": 10
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "command": "node \"${COPILOT_PLUGIN_ROOT}\"/hooks/user-prompt-submit.js",
        "timeoutSec": 10
      }
    ]
  }
}
