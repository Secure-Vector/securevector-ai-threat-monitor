include README.md
include LICENSE
include NOTICE
include CONTRIBUTOR_AGREEMENT.md
recursive-include rules *.yaml
recursive-include rules *.yml
include rules/README.md
include rules/RULES_ATTRIBUTION.md
include rules/LICENSE_NOTICE.md
recursive-include src/securevector/plugins/claude-code *
recursive-include src/securevector/plugins/claude-code/.claude-plugin *
recursive-include src/securevector/plugins/codex *
recursive-include src/securevector/plugins/codex/.codex-plugin *
global-exclude __pycache__
global-exclude *.py[co]
global-exclude *.pyo
global-exclude .git*
global-exclude .DS_Store
prune tests
prune demo
prune docs
prune .github